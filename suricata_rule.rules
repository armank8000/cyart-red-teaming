# ─────────────────────────────────────────────────────────────────
# Suricata Rules — Week 2 Network Defense Task
# CYART Red Teaming Apprenticeship
# ─────────────────────────────────────────────────────────────────

# Rule 1: Block a known malicious IP
drop ip 192.168.1.100 any -> any any (msg:"Block Malicious IP - C2 Communication"; sid:1000001; rev:1;)

# Rule 2: Detect suspicious HTTP outbound (possible C2)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Suspicious Outbound HTTP - Possible C2 T1071"; \
  flow:established,to_server; \
  http.method; content:"GET"; \
  http.uri; content:"/beacon"; \
  classtype:trojan-activity; sid:1000002; rev:1;)

# Rule 3: Detect PowerShell download cradle over HTTP
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"PowerShell Download Cradle Detected T1059.001"; \
  flow:established,to_server; \
  http.user_agent; content:"PowerShell"; nocase; \
  classtype:trojan-activity; sid:1000003; rev:1;)

# Rule 4: Detect VSFTPD exploit attempt (Capstone — T1190)
alert tcp $EXTERNAL_NET any -> $HOME_NET 21 (msg:"VSFTPD 2.3.4 Backdoor Attempt T1190"; \
  flow:established,to_server; \
  content:":)"; \
  classtype:attempted-admin; sid:1000004; rev:1;)

# ─────────────────────────────────────────────────────────────────
# MITRE ATT&CK Mapping
#
# | SID     | Alert                     | Tactic              | Technique |
# |---------|---------------------------|---------------------|-----------|
# | 1000001 | Block Malicious IP        | Command and Control | T1071     |
# | 1000002 | Suspicious Outbound HTTP  | Command and Control | T1071.001 |
# | 1000003 | PowerShell Download Cradle| Execution           | T1059.001 |
# | 1000004 | VSFTPD Backdoor Attempt   | Initial Access      | T1190     |
#
# HOW TO TEST Rule 1:
#   From attacker VM: ping 192.168.1.100
#   Expected: Traffic dropped, alert in /var/log/suricata/fast.log
#
# HOW TO RELOAD RULES:
#   sudo suricatasc -c reload-rules
# ─────────────────────────────────────────────────────────────────
